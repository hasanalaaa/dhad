# Normalize source and documentation line endings.
* text=auto eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# The production neural model exceeds GitHub's normal 100 MiB object limit.
*.onnx filter=lfs diff=lfs merge=lfs -text

# Keep generated/binary assets out of textual diffs.
*.wasm binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.zip binary
