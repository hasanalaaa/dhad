{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dhad.dev/schemas/dialects.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "dialects", "entries", "desire_forms", "verb_forms"],
  "properties": {
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "dialects": {
      "type": "object",
      "minProperties": 5,
      "additionalProperties": false,
      "required": ["egyptian", "levantine", "gulf", "iraqi", "maghrebi"],
      "properties": {
        "egyptian": {"$ref": "#/$defs/dialect"},
        "levantine": {"$ref": "#/$defs/dialect"},
        "gulf": {"$ref": "#/$defs/dialect"},
        "iraqi": {"$ref": "#/$defs/dialect"},
        "maghrebi": {"$ref": "#/$defs/dialect"}
      }
    },
    "entries": {
      "type": "array",
      "minItems": 50,
      "items": {"$ref": "#/$defs/entry"}
    },
    "desire_forms": {
      "type": "array",
      "minItems": 10,
      "items": {"$ref": "#/$defs/desire"}
    },
    "verb_forms": {
      "type": "object",
      "minProperties": 15,
      "additionalProperties": {"$ref": "#/$defs/verb"}
    }
  },
  "$defs": {
    "dialect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name_ar"],
      "properties": {"name_ar": {"type": "string", "minLength": 2}}
    },
    "dialectName": {"enum": ["egyptian", "levantine", "gulf", "iraqi", "maghrebi"]},
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "dialects", "forms", "msa", "weight", "confidence", "kind", "explanation"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
        "dialects": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/dialectName"}},
        "forms": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "msa": {"type": "string", "minLength": 1},
        "weight": {"type": "number", "exclusiveMinimum": 0, "maximum": 3},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "kind": {"enum": ["lexical", "phrase"]},
        "explanation": {"type": "string", "minLength": 1}
      }
    },
    "desire": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forms", "dialects", "person"],
      "properties": {
        "forms": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "dialects": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/dialectName"}},
        "person": {"enum": ["1s", "1p", "2s", "2p", "2_or_3f", "3m", "3f", "3p"]}
      }
    },
    "verb": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [{"required": ["msa"]}, {"required": ["msa_by_person"]}],
      "properties": {
        "msa": {"type": "string", "minLength": 1},
        "person": {"type": "string", "minLength": 2},
        "msa_by_person": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "minLength": 1}}
      }
    }
  }
}
