{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "version", "license", "entries"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 1},
    "version": {"type": "string", "minLength": 1},
    "license": {"type": "string", "minLength": 1},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["lemma", "pos", "frequency"],
        "additionalProperties": false,
        "properties": {
          "lemma": {"type": "string", "minLength": 1},
          "root": {"type": ["string", "null"]},
          "pattern": {"type": ["string", "null"]},
          "pos": {"enum": ["noun", "verb", "adjective", "particle", "pronoun", "proper_noun", "verbal_noun", "adverb"]},
          "frequency": {"type": "integer", "minimum": 1},
          "features": {"type": "object", "additionalProperties": {"type": ["string", "number", "boolean"]}},
          "forms": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["form"],
              "additionalProperties": false,
              "properties": {
                "form": {"type": "string", "minLength": 1},
                "features": {"type": "object", "additionalProperties": {"type": ["string", "number", "boolean"]}}
              }
            }
          }
        }
      }
    }
  }
}
